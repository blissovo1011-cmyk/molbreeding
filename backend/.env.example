# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=molbreeding

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# MIMS API (Optional)
MIMS_MAINLAND_API_URL=http://mims-mainland-api.example.com
MIMS_OVERSEAS_API_URL=http://mims-overseas-api.example.com
MIMS_API_KEY=your_mims_api_key
